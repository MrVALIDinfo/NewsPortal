datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  role         String    @default("USER") // USER | ADMIN
  name         String
  avatarUrl    String?
  // Поля, необходимые для совместимости с фронтендом:
  initials     String?
  color        String?
  bio          String?
  createdAt    DateTime  @default(now())
  posts        Post[]
  comments     Comment[]
}

model Post {
  id        String    @id @default(uuid())
  title     String
  excerpt   String?
  content   String
  imageUrl  String?
  category  String
  tags      String    // Хранение в виде JSON строки или через запятую (ограничение SQLite)
  authorId  String
  author    User      @relation(fields: [authorId], references: [id])
  views     Int       @default(0)
  readTime  Int       @default(5)
  featured  Boolean   @default(false)
  createdAt DateTime  @default(now())
  comments  Comment[]
}

model Comment {
  id            String   @id @default(uuid())
  content       String
  imageUrl      String?
  postId        String
  post          Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId      String?
  author        User?    @relation(fields: [authorId], references: [id])
  guestName     String?
  guestInitials String?
  guestColor    String?
  status        String   @default("approved") // approved | pending | rejected
  createdAt     DateTime @default(now())
}
